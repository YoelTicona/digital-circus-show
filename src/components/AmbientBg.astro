---
// AmbientBg.astro — fondo atmosférico del circo (OPTIMIZADO PARA RENDIMIENTO)
// Sin blur(), sin clip-path, animaciones aceleradas por hardware.
---

<div class="ambient" aria-hidden="true">

  <!-- Halo central pulsante detrás de la TV -->
  <div class="halo halo-center"></div>
  <div class="halo halo-left"></div>
  <div class="halo halo-right"></div>

  <!-- Focos de escenario: Creados con gradientes radiales (Cero costo de GPU) -->
  <div class="cone cone-l1"></div>
  <div class="cone cone-l2"></div>
  <div class="cone cone-r1"></div>
  <div class="cone cone-r2"></div>
  <div class="cone cone-top"></div>

  <!-- Estrellas -->
  {[
    [12, 18, 2.5, 3.2, 0.4], [9,  47, 3.0, 2.8, 0.7], [14, 73, 2.2, 3.5, 0.3],
    [3,  93, 2.8, 1.9, 0.9], [16, 55, 1.6, 1.7, 2.5], [4,  70, 3.2, 2.2, 0.5],
    [33, 82, 2.6, 2.7, 0.2], [22, 25, 2.0, 2.6, 0.6], [8,  5,  1.5, 2.1, 0.0],
    [5,  32, 1.2, 1.8, 1.1], [25, 90, 1.4, 2.3, 1.7], [28, 50, 1.2, 1.6, 2.8]
  ].map(([top, left, size, dur, delay]) => (
    <span
      class="star"
      style={`top:${top}%;left:${left}%;width:${size}px;height:${size}px;animation-duration:${dur}s;animation-delay:${delay}s`}
    />
  ))}

  <!-- Partículas de luz flotantes (Sin box-shadow para evitar repaints) -->
  {[
    { left: 8,  color: 'rgba(241,196,14,0.8)', dur: 7.0, delay: 0.0, size: 4 },
    { left: 35, color: 'rgba(51,152,219,0.8)', dur: 8.0, delay: 3.1, size: 5 },
    { left: 63, color: 'rgba(46,204,112,0.8)', dur: 10.0,delay: 2.3, size: 4 },
    { left: 88, color: 'rgba(241,196,14,0.8)', dur: 8.5, delay: 1.8, size: 4 },
    { left: 15, color: 'rgba(122,0,204,0.8)',  dur: 9.0, delay: 5.0, size: 3 },
    { left: 42, color: 'rgba(231,77,60,0.8)',  dur: 7.2, delay: 2.7, size: 5 },
    { left: 70, color: 'rgba(46,204,112,0.8)', dur: 6.8, delay: 3.5, size: 4 },
    { left: 30, color: 'rgba(255,79,163,0.8)', dur: 7.8, delay: 4.8, size: 4 },
    { left: 82, color: 'rgba(241,196,14,0.8)', dur: 8.3, delay: 2.0, size: 3 }
  ].map(p => (
    <span
      class="particle"
      style={`left:${p.left}%;background:${p.color};width:${p.size}px;height:${p.size}px;animation-duration:${p.dur}s;animation-delay:${p.delay}s;`}
    />
  ))}

  <!-- Confeti que cae -->
  {[
    { left: 12, color: '#f1c40e', dur: 6.5, delay: 2.1, shape: 'circle', size: 5, drift: -30 },
    { left: 20, color: '#2ecc70', dur: 9.0, delay: 0.8, shape: 'square', size: 8, drift:  55 },
    { left: 28, color: '#3398db', dur: 7.0, delay: 3.5, shape: 'ribbon', size: 4, drift: -45 },
    { left: 45, color: '#7a00cc', dur: 6.0, delay: 4.2, shape: 'square', size: 7, drift: -60 },
    { left: 53, color: '#ff4fa3', dur: 9.5, delay: 0.5, shape: 'ribbon', size: 4, drift:  50 },
    { left: 62, color: '#e74d3c', dur: 7.5, delay: 2.8, shape: 'circle', size: 5, drift: -35 },
    { left: 70, color: '#f1c40e', dur: 8.2, delay: 1.6, shape: 'square', size: 9, drift:  45 },
    { left: 85, color: '#3398db', dur: 9.2, delay: 0.2, shape: 'ribbon', size: 4, drift:  30 },
    { left: 92, color: '#f39c12', dur: 7.8, delay: 4.6, shape: 'square', size: 7, drift: -40 },
    { left: 16, color: '#ff4fa3', dur: 10.0,delay: 1.0, shape: 'circle', size: 5, drift:  60 },
    { left: 57, color: '#e74d3c', dur: 8.7, delay: 2.4, shape: 'ribbon', size: 4, drift:  40 },
    { left: 74, color: '#f1c40e', dur: 6.3, delay: 3.2, shape: 'circle', size: 6, drift: -55 },
  ].map((p) => (
    <span
      class="confetti-piece"
      style={`
        left:${p.left}%;
        background:${p.color};
        width:${p.shape === 'ribbon' ? p.size + 'px' : p.size + 'px'};
        height:${p.shape === 'ribbon' ? p.size * 3 + 'px' : p.size + 'px'};
        border-radius:${p.shape === 'circle' ? '50%' : p.shape === 'ribbon' ? '2px' : '1px'};
        animation-duration:${p.dur}s;
        animation-delay:${p.delay}s;
        --drift:${p.drift}px;
      `}
    />
  ))}

</div>

<style>
  /* ── Base ── */
  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    background: #080010;
  }

  /* ── Halos difusos ── */
  .halo {
    position: absolute;
    border-radius: 50%;
    will-change: transform, opacity;
    transform: translateZ(0); /* Aceleración GPU estricta */
  }

  .halo-center {
    width: 70vw; height: 50vh; top: 15%; left: 50%;
    margin-left: -35vw; /* Mejor que translateX para combinar con animaciones */
    background: radial-gradient(ellipse at center, rgba(122, 0, 204, 0.22) 0%, rgba(60, 0, 100, 0.12) 40%, transparent 70%);
    animation: halo-breathe 8s ease-in-out infinite;
  }

  .halo-left {
    width: 45vw; height: 60vh; top: -5%; left: -8%;
    background: radial-gradient(ellipse at center, rgba(231, 77, 60, 0.12) 0%, rgba(243, 156, 18, 0.06) 50%, transparent 70%);
    animation: halo-side-breathe 11s ease-in-out infinite 2s;
  }

  .halo-right {
    width: 45vw; height: 60vh; top: -5%; right: -8%;
    background: radial-gradient(ellipse at center, rgba(51, 152, 219, 0.12) 0%, rgba(46, 204, 112, 0.06) 50%, transparent 70%);
    animation: halo-side-breathe 9s ease-in-out infinite 4s;
  }

  @keyframes halo-breathe {
    0%, 100% { opacity: 0.7; transform: translateZ(0) scale(1); }
    50%       { opacity: 1.0; transform: translateZ(0) scale(1.08); }
  }

  @keyframes halo-side-breathe {
    0%, 100% { opacity: 0.6; transform: translateZ(0) scale(1); }
    50%       { opacity: 0.9; transform: translateZ(0) scale(1.1); }
  }

  /* ── Conos de luz (Reescritos con Radial-Gradient en vez de Clip-path+Blur) ── */
  .cone {
    position: absolute;
    top: -10%; /* Lo subimos un poco para ocultar el origen */
    transform-origin: top center;
    will-change: transform, opacity;
    transform: translateZ(0); /* Aceleración GPU */
  }

  .cone-l1 {
    left: -10%; width: 50vw; height: 70vh;
    background: radial-gradient(ellipse at 50% 10%, rgba(241, 196, 14, 0.18) 0%, transparent 60%);
    animation: cone-sway 9s ease-in-out infinite;
    --sway: -12deg; --sway-end: -4deg;
  }

  .cone-l2 {
    left: 0%; width: 40vw; height: 60vh;
    background: radial-gradient(ellipse at 50% 10%, rgba(231, 77, 60, 0.15) 0%, transparent 55%);
    animation: cone-sway 12s ease-in-out infinite 3s;
    --sway: -8deg; --sway-end: 2deg;
  }

  .cone-r1 {
    right: -10%; width: 50vw; height: 70vh;
    background: radial-gradient(ellipse at 50% 10%, rgba(51, 152, 219, 0.18) 0%, transparent 60%);
    animation: cone-sway 10s ease-in-out infinite 1.5s;
    --sway: 4deg; --sway-end: 14deg;
  }

  .cone-r2 {
    right: 5%; width: 40vw; height: 60vh;
    background: radial-gradient(ellipse at 50% 10%, rgba(255, 79, 163, 0.15) 0%, transparent 55%);
    animation: cone-sway 13s ease-in-out infinite 5s;
    --sway: 2deg; --sway-end: 12deg;
  }

  .cone-top {
    left: 50%; margin-left: -25vw; width: 50vw; height: 65vh;
    background: radial-gradient(ellipse at 50% 10%, rgba(255, 255, 255, 0.08) 0%, rgba(241, 196, 14, 0.03) 40%, transparent 65%);
    animation: cone-center-breathe 7s ease-in-out infinite;
  }

  @keyframes cone-sway {
    0%, 100% { transform: translateZ(0) rotate(var(--sway)); opacity: 0.7; }
    50%       { transform: translateZ(0) rotate(var(--sway-end)); opacity: 1.0; }
  }

  @keyframes cone-center-breathe {
    0%, 100% { opacity: 0.5; transform: translateZ(0) scaleX(1); }
    50%       { opacity: 0.9; transform: translateZ(0) scaleX(1.15); }
  }

  /* ── Estrellas ── */
  .star {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.8);
    /* Sombras simplificadas estáticas */
    box-shadow: 0 0 4px rgba(255, 255, 255, 0.4);
    animation: star-twinkle var(--dur, 2.5s) ease-in-out infinite;
  }

  @keyframes star-twinkle {
    0%, 100% { opacity: 0.2; transform: scale(0.7); }
    50%       { opacity: 1; transform: scale(1.1); }
  }

  /* ── Partículas y Confeti (SIN will-change para no asfixiar la memoria RAM) ── */
  .particle, .confetti-piece {
    position: absolute;
  }

  .particle {
    bottom: -8px;
    border-radius: 50%;
    animation: particle-rise linear infinite;
  }

  @keyframes particle-rise {
    0%   { transform: translateY(0) translateX(0) scale(1); opacity: 0; }
    10%  { opacity: 1; }
    80%  { opacity: 0.5; }
    100% { transform: translateY(-100vh) translateX(20px) scale(0.3); opacity: 0; }
  }

  .confetti-piece {
    top: -16px;
    opacity: 0.8;
    animation: confetti-drift linear infinite;
  }

  @keyframes confetti-drift {
    0%   { transform: translateY(0) translateX(0) rotate(0deg); opacity: 0; }
    5%   { opacity: 1; }
    85%  { opacity: 0.8; }
    100% { transform: translateY(105vh) translateX(var(--drift, 40px)) rotate(540deg); opacity: 0; }
  }
</style>