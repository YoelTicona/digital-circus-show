---
// AmbientBg.astro — fondo atmosférico del circo
// Sin líneas tajantes: todo difuso, volumétrico, suave
---

<div class="ambient" aria-hidden="true">

  <!-- Halo central pulsante detrás de la TV -->
  <div class="halo halo-center"></div>
  <div class="halo halo-left"></div>
  <div class="halo halo-right"></div>

  <!-- Focos de escenario: cones amplios y difusos, no líneas -->
  <div class="cone cone-l1"></div>
  <div class="cone cone-l2"></div>
  <div class="cone cone-r1"></div>
  <div class="cone cone-r2"></div>
  <div class="cone cone-top"></div>

  <!-- Estrellas: tamaños variados, algunas con glow propio -->
  {[
    // [top%, left%, size_px, dur_s, delay_s, glow]
    [8,  5,  1.5, 2.1, 0.0,  false],
    [12, 18, 2.5, 3.2, 0.4,  true ],
    [5,  32, 1.2, 1.8, 1.1,  false],
    [9,  47, 3.0, 2.8, 0.7,  true ],
    [6,  61, 1.8, 2.4, 1.8,  false],
    [14, 73, 2.2, 3.5, 0.3,  true ],
    [7,  85, 1.5, 2.0, 2.2,  false],
    [3,  93, 2.8, 1.9, 0.9,  true ],
    [18, 8,  1.2, 3.0, 1.4,  false],
    [22, 25, 2.0, 2.6, 0.6,  false],
    [16, 55, 1.6, 1.7, 2.5,  true ],
    [20, 78, 2.4, 3.1, 0.1,  false],
    [25, 90, 1.4, 2.3, 1.7,  false],
    [11, 40, 1.0, 2.9, 3.0,  false],
    [4,  70, 3.2, 2.2, 0.5,  true ],
    [30, 15, 1.8, 3.4, 1.2,  false],
    [28, 50, 1.2, 1.6, 2.8,  false],
    [33, 82, 2.6, 2.7, 0.2,  true ],
    [15, 96, 1.4, 3.3, 1.6,  false],
    [26, 3,  2.0, 2.0, 2.1,  false],
  ].map(([top, left, size, dur, delay, glow]) => (
    <span
      class={`star ${glow ? 'star--glow' : ''}`}
      style={`top:${top}%;left:${left}%;width:${size}px;height:${size}px;animation-duration:${dur}s;animation-delay:${delay}s`}
    />
  ))}

  <!-- Partículas de luz flotantes (no confeti que cae — puntos de luz que suben y desaparecen) -->
  {[
    { left: 8,  color: '#f1c40e', dur: 7.0, delay: 0.0, size: 3 },
    { left: 22, color: '#e74d3c', dur: 9.5, delay: 1.2, size: 2 },
    { left: 35, color: '#3398db', dur: 8.0, delay: 3.1, size: 4 },
    { left: 50, color: '#f39c12', dur: 6.5, delay: 0.5, size: 2 },
    { left: 63, color: '#2ecc70', dur: 10.0,delay: 2.3, size: 3 },
    { left: 75, color: '#ff4fa3', dur: 7.5, delay: 4.0, size: 2 },
    { left: 88, color: '#f1c40e', dur: 8.5, delay: 1.8, size: 3 },
    { left: 15, color: '#7a00cc', dur: 9.0, delay: 5.0, size: 2 },
    { left: 42, color: '#e74d3c', dur: 7.2, delay: 2.7, size: 4 },
    { left: 58, color: '#3398db', dur: 8.8, delay: 0.9, size: 2 },
    { left: 70, color: '#2ecc70', dur: 6.8, delay: 3.5, size: 3 },
    { left: 95, color: '#f39c12', dur: 9.2, delay: 1.4, size: 2 },
    { left: 30, color: '#ff4fa3', dur: 7.8, delay: 4.8, size: 3 },
    { left: 82, color: '#f1c40e', dur: 8.3, delay: 2.0, size: 2 },
    { left: 48, color: '#7a00cc', dur: 11.0,delay: 0.3, size: 4 },
  ].map(p => (
    <span
      class="particle"
      style={`
        left:${p.left}%;
        background:${p.color};
        width:${p.size}px;
        height:${p.size}px;
        animation-duration:${p.dur}s;
        animation-delay:${p.delay}s;
        box-shadow: 0 0 ${p.size * 3}px ${p.color};
      `}
    />
  ))}

  <!-- Confeti: formas variadas que caen con drift lateral — más festivo, menos genérico -->
  {[
    { left: 5,  color: '#e74d3c', dur: 8.0, delay: 0.0,  shape: 'square',   size: 7,  drift:  40 },
    { left: 12, color: '#f1c40e', dur: 6.5, delay: 2.1,  shape: 'circle',   size: 5,  drift: -30 },
    { left: 20, color: '#2ecc70', dur: 9.0, delay: 0.8,  shape: 'square',   size: 8,  drift:  55 },
    { left: 28, color: '#3398db', dur: 7.0, delay: 3.5,  shape: 'ribbon',   size: 4,  drift: -45 },
    { left: 38, color: '#f39c12', dur: 8.5, delay: 1.3,  shape: 'circle',   size: 6,  drift:  35 },
    { left: 45, color: '#7a00cc', dur: 6.0, delay: 4.2,  shape: 'square',   size: 7,  drift: -60 },
    { left: 53, color: '#ff4fa3', dur: 9.5, delay: 0.5,  shape: 'ribbon',   size: 4,  drift:  50 },
    { left: 62, color: '#e74d3c', dur: 7.5, delay: 2.8,  shape: 'circle',   size: 5,  drift: -35 },
    { left: 70, color: '#f1c40e', dur: 8.2, delay: 1.6,  shape: 'square',   size: 9,  drift:  45 },
    { left: 78, color: '#2ecc70', dur: 6.8, delay: 3.9,  shape: 'circle',   size: 6,  drift: -50 },
    { left: 85, color: '#3398db', dur: 9.2, delay: 0.2,  shape: 'ribbon',   size: 4,  drift:  30 },
    { left: 92, color: '#f39c12', dur: 7.8, delay: 4.6,  shape: 'square',   size: 7,  drift: -40 },
    { left: 16, color: '#ff4fa3', dur: 10.0,delay: 1.0,  shape: 'circle',   size: 5,  drift:  60 },
    { left: 33, color: '#7a00cc', dur: 7.2, delay: 5.1,  shape: 'square',   size: 8,  drift: -25 },
    { left: 57, color: '#e74d3c', dur: 8.7, delay: 2.4,  shape: 'ribbon',   size: 4,  drift:  40 },
    { left: 74, color: '#f1c40e', dur: 6.3, delay: 3.2,  shape: 'circle',   size: 6,  drift: -55 },
    { left: 88, color: '#2ecc70', dur: 9.8, delay: 0.7,  shape: 'square',   size: 7,  drift:  35 },
    { left: 3,  color: '#3398db', dur: 7.4, delay: 4.0,  shape: 'circle',   size: 5,  drift: -30 },
  ].map((p, i) => (
    <span
      class="confetti-piece"
      style={`
        left:${p.left}%;
        background:${p.color};
        width:${p.shape === 'ribbon' ? p.size + 'px' : p.size + 'px'};
        height:${p.shape === 'ribbon' ? p.size * 3 + 'px' : p.size + 'px'};
        border-radius:${p.shape === 'circle' ? '50%' : p.shape === 'ribbon' ? '2px' : '1px'};
        animation-duration:${p.dur}s;
        animation-delay:${p.delay}s;
        --drift:${p.drift}px;
        opacity:0.82;
      `}
    />
  ))}

</div>

<style>
  /* ── Base ── */
  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    background: #080010;
  }

  /* ── Halos difusos — la magia principal ────────────────────────
     Nada de líneas. Todo son elipses grandes con blur enorme.
     Dan la sensación de que hay luz detrás de la TV sin ser obvios.
  ─────────────────────────────────────────────────────────────── */
  
