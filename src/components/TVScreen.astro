---
// TVScreen.astro
// Pantalla interactiva: Requiere encendido previo para revelar contenido y audio.
interface Props {
  maxWidth?: string
  class?: string
}

const { maxWidth, class: className = '' } = Astro.props
---

<div class:list={['tv-wrapper', className]} id="magic-tv" data-state="off" style={maxWidth ? `--tv-max: ${maxWidth}` : ''}>
  
  <!-- Imagen de la TV (Por defecto arranca apagada) -->
  <img
    src="/images/tv-circo-digital-off.png" 
    data-on-src="/images/tv-circo-digital-on.png"
    id="tv-main-image"
    alt="Television del Circo Digital"
    class="tv-image"
    draggable="false"
  />

  <!-- Texto flotante indicando la acción -->
  <div id="turn-on-hint" class="turn-on-hint font-display">
    ¡HAZ CLIC EN LA TV PARA ENCENDER!
  </div>

  <!-- Contenido de la pantalla (Oculto al inicio mediante opacidad) -->
  <div id="tv-screen-content" class="tv-screen" style="opacity: 0; pointer-events: none; transition: opacity 0.5s ease;">
    <div class="tv-scanlines" aria-hidden="true"></div>
    <div class="tv-screen-inner">
      <slot>
        <div class="tv-static">
          <span class="font-display text-[var(--circus-yellow)] text-2xl tracking-widest">
            SEÑAL INTERRUMPIDA...
          </span>
        </div>
      </slot>
    </div>
  </div>

  <!-- Resplandor trasero (Oculto al inicio) -->
  <div id="tv-glow-effect" class="tv-glow" style="opacity: 0; transition: opacity 0.5s ease;"></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tv = document.getElementById('magic-tv');
    const tvImg = document.getElementById('tv-main-image') as HTMLImageElement;
    const hint = document.getElementById('turn-on-hint');
    const screen = document.getElementById('tv-screen-content');
    const glow = document.getElementById('tv-glow-effect');

    if (tv) {
      tv.style.cursor = 'pointer';

      tv.addEventListener('click', (e) => {
        e.stopPropagation(); 
        const state = tv.getAttribute('data-state');
        const music = document.getElementById('bg-music') as HTMLAudioElement;

        // ─── PRIMER CLIC: ENCENDER LA TV ──────────────────────────────
        if (state === 'off') {
          // 1. Cambiamos el estado para que el próximo clic abra el banner
          tv.setAttribute('data-state', 'on');

          // 2. Mostramos "la otra foto" (TV encendida)
          if (tvImg && tvImg.dataset.onSrc) {
            tvImg.src = tvImg.dataset.onSrc;
          }

          // 3. Ocultamos el texto de "Haz clic" y mostramos el contador/video
          if (hint) hint.style.opacity = '0';
          if (screen) {
            screen.style.opacity = '1';
            screen.style.pointerEvents = 'auto'; 
          }
          if (glow) glow.style.opacity = '1';

          // 4. Arrancamos la música
          if (music && music.paused) {
            music.play().catch(err => console.log("Audio bloqueado:", err));
            document.getElementById('icon-muted')?.classList.add('hidden');
            document.getElementById('icon-playing')?.classList.remove('hidden');
            document.getElementById('mute-btn')?.classList.add('is-playing');
          }
        } 
        
        // ─── SEGUNDO CLIC (Y SIGUIENTES): MOSTRAR EL BANNER ───────────
        else if (state === 'on') {
          tv.setAttribute('data-state', 'banner');
          const modalBanner = document.getElementById('circus-modal-banner');
          modalBanner?.classList.add('is-visible');
        }
      });
      // 3. Lógica para cerrar el banner y volver a estado ON
      // Esto se pone en el listener de cierre que ya tenías
      const modal = document.getElementById('circus-modal-banner');
      modal?.addEventListener('click', () => {
        tv?.setAttribute('data-state', 'on');
      });
    }
  });
</script>

<style>
  /* ── Contenedor principal ── */
  .tv-wrapper {
    --tv-max: min(95vw, 700px);
    position: relative;
    width: var(--tv-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: tv-float 6s ease-in-out infinite;
  }

  /* ── Hint de encendido (Lógica corregida) ── */
  .turn-on-hint {
    /* Por defecto: Desktop (Esquina superior derecha fuera de la TV) */
    position: absolute;
    top: 5%;
    right: -15%;
    z-index: 20;
    
    font-size: clamp(0.9rem, 2vw, 1.2rem);
    color: var(--circus-yellow);
    text-shadow: 0 0 10px rgba(0,0,0,0.8), 2px 2px 0 #7a4400;
    text-align: center;
    pointer-events: none;
    transition: opacity 0.3s ease;
    animation: pulse-glow 1.5s infinite;
    --glow-color: var(--circus-yellow);
    white-space: nowrap;
  }
  .tv-screen {
    position: absolute;
    /* Ajustado para que el área de pantalla sea más precisa respecto al marco */
    top: 21%; 
    left: 20%; 
    width: 58%; 
    height: 55%;
    z-index: 2;
    overflow: hidden;
    border-radius: 15px;
    background: #000;
  }

  /* Media Query para móvil: Debajo de la TV */
  @media (max-width: 768px) {
    .turn-on-hint {
      position: relative; /* Se coloca en el flujo del flex-column */
      margin-top: 1.5rem;
      font-size: 1.4rem;
    }

    .tv-screen {
      position: absolute;
      /* Ajustado para que el área de pantalla sea más precisa respecto al marco */
      top: 13%; 
      left: 20%; 
      width: 58%; 
      height: 55%;
      z-index: 2;
      overflow: hidden;
      border-radius: 50px;
      background: #000;
    }
  }

  /* ── TV Imagen y elementos internos (Sin cambios) ── */
  .tv-image {
    display: block;
    width: 100%;
    height: auto;
    position: relative;
    z-index: 3;
    user-select: none;
    filter: saturate(1.15) contrast(1.05);
    transition: filter 0.3s ease;
  }

  .tv-scanlines {
    position: absolute; inset: 0; z-index: 10; pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.25) 2px, rgba(0, 0, 0, 0.25) 4px);
    animation: scanline-move 0.4s linear infinite;
  }

  .tv-screen-inner {
    position: absolute; inset: 0; z-index: 5; display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  
  .tv-screen-inner > :global(*) { width: 100%; height: 100%; }
  
  .tv-glow {
    position: absolute; inset: -10%; z-index: 1; border-radius: 50%;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--circus-purple) 25%, transparent) 0%, color-mix(in srgb, var(--circus-red) 10%, transparent) 40%, transparent 80%);
  }

  @keyframes tv-float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    30%      { transform: translateY(-6px) rotate(0.3deg); }
    70%      { transform: translateY(-3px) rotate(-0.2deg); }
  }
</style>