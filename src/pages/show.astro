---
import BaseLayout from '../layouts/BaseLayout.astro'
import AmbientBg  from '../components/AmbientBg.astro'
import Countdown  from '../components/Countdown.vue'
---

<BaseLayout
  title="The Amazing Digital Circus — 05 de Julio"
  description="Show en vivo con todos los personajes. 05 de Julio · 5:00 PM · Cámara Nacional de Comercio, Bolivia."
>

  <AmbientBg />

  <main class="page-show">

    <!-- ── Header ── -->
    <header class="show-header">
      <p class="pre-title font-display">¡Con todos los personajes en vivo!</p>
      <h1 class="main-title font-display">
        The Amazing<br />
        <span class="accent">Digital Circus</span>
      </h1>
    </header>

    <!-- ── Countdown banner ── -->
    <section class="countdown-section" aria-label="Cuenta regresiva">
      <Countdown client:load />
    </section>

    <!-- ── Event card ── -->
    <section class="event-card" aria-label="Datos del evento">
      <div class="event-date font-display">05 DE JULIO · 5:00 PM</div>
      <p class="event-venue">
        Cámara Nacional de Comercio<br />
        <span class="muted">A solo 2 cuadras del Obelisco · Única función</span>
      </p>
    </section>

    <!-- ── Features grid ── -->
    <section class="features" aria-label="Qué incluye">
      {[
        { icon: '🎭', label: 'Show en vivo apto para todo público' },
        { icon: '📸', label: 'Fotos con los personajes' },
        { icon: '🎵', label: 'Música y baile' },
        { icon: '🎪', label: 'Escenografía y show interactivo' },
        { icon: '🛍️', label: 'Stands de productos de la serie' },
        { icon: '🎮', label: 'Juegos y actividades' },
        { icon: '🎁', label: 'Sorteos y muchas sorpresas' },
        { icon: '🏆', label: 'Premios para el mejor cosplay' },
      ].map(f => (
        <div class="feature-pill">
          <span class="feature-icon" aria-hidden="true">{f.icon}</span>
          <span class="feature-label">{f.label}</span>
        </div>
      ))}
    </section>

    <!-- ── Cosplay callout ── -->
    <div class="cosplay-callout" role="note">
      <span class="cosplay-badge font-display">COSPLAY</span>
      <p>Ven disfrazado de tu personaje favorito del Digital Circus y participa por premios especiales.</p>
    </div>

    <!-- ── CTA ── -->
    <div class="cta-area">
      <a
        href="https://wa.me/59171505241"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn font-display"
      >
        🎟 RESERVA TU ENTRADA
      </a>
      <p class="cta-sub">WhatsApp: 71505241 · Entradas limitadas</p>
    </div>

    <!-- ── Back link ── -->
    <a href="/" class="back-link">← Volver</a>

  </main>

</BaseLayout>

<style>
  .page-show {
    position: relative;
    z-index: 1;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 2rem);
    gap: clamp(1.5rem, 4vh, 2.5rem);
    max-width: 640px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .show-header { text-align: center; }

  .pre-title {
    font-size: clamp(0.75rem, 2.5vw, 0.95rem);
    letter-spacing: 0.2em;
    color: var(--circus-yellow);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
    text-shadow: 0 0 12px color-mix(in srgb, var(--circus-yellow) 50%, transparent);
  }

  .main-title {
    font-size: clamp(2.2rem, 10vw, 4rem);
    line-height: 1.05;
    color: #fff;
    text-shadow:
      3px 3px 0 var(--circus-purple),
      -1px -1px 0 var(--circus-pink),
      0 0 30px color-mix(in srgb, var(--circus-pink) 40%, transparent);
  }

  .main-title .accent { color: var(--circus-yellow); }

  /* ── Countdown ── */
  .countdown-section { width: 100%; }

  /* ── Event card ── */
  .event-card {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(231, 77, 60, 0.3);
    border-radius: 12px;
    padding: clamp(0.875rem, 3vw, 1.25rem) clamp(1rem, 4vw, 1.5rem);
    text-align: center;
  }

  .event-date {
    font-size: clamp(1.1rem, 4vw, 1.5rem);
    color: var(--circus-red);
    text-shadow: 0 0 12px color-mix(in srgb, var(--circus-red) 60%, transparent);
    margin-bottom: 0.4rem;
    letter-spacing: 0.05em;
  }

  .event-venue {
    font-size: clamp(0.8rem, 2.5vw, 0.95rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.6;
  }

  .muted { color: rgba(255, 255, 255, 0.45); }

  /* ── Features ── */
  .features {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    width: 100%;
  }

  .feature-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(51, 152, 219, 0.25);
    border-radius: 20px;
    padding: 5px 12px;
    font-size: clamp(0.7rem, 2vw, 0.82rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.8);
  }

  .feature-icon { font-size: 1rem; }

  /* ── Cosplay callout ── */
  .cosplay-callout {
    width: 100%;
    background: rgba(122, 0, 204, 0.15);
    border: 1px dashed rgba(122, 0, 204, 0.5);
    border-radius: 12px;
    padding: clamp(0.75rem, 3vw, 1rem) clamp(1rem, 4vw, 1.25rem);
    text-align: center;
  }

  .cosplay-badge {
    display: inline-block;
    background: var(--circus-purple);
    color: #fff;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    padding: 2px 12px;
    border-radius: 20px;
    margin-bottom: 8px;
  }

  .cosplay-callout p {
    font-size: clamp(0.8rem, 2.5vw, 0.9rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
  }

  /* ── CTA ── */
  .cta-area { text-align: center; }

  .cta-btn {
    display: inline-block;
    font-size: clamp(1.1rem, 4vw, 1.4rem);
    letter-spacing: 0.1em;
    color: #080010;
    background: linear-gradient(135deg, var(--circus-yellow), var(--circus-orange));
    border-radius: 50px;
    padding: clamp(0.65rem, 2vw, 0.85rem) clamp(1.5rem, 5vw, 2.5rem);
    text-decoration: none;
    box-shadow:
      0 4px 20px color-mix(in srgb, var(--circus-yellow) 40%, transparent),
      0 0 40px color-mix(in srgb, var(--circus-orange) 25%, transparent);
    animation: pulse-glow 2s ease-in-out infinite;
    --glow-color: var(--circus-yellow);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .cta-btn:hover {
    transform: scale(1.04);
    box-shadow:
      0 6px 28px color-mix(in srgb, var(--circus-yellow) 55%, transparent),
      0 0 60px color-mix(in srgb, var(--circus-orange) 35%, transparent);
  }

  .cta-sub {
    margin-top: 8px;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.05em;
  }

  /* ── Back ── */
  .back-link {
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s;
    padding-bottom: 1rem;
  }
  .back-link:hover { color: rgba(255, 255, 255, 0.7); }
</style>
